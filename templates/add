<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        :root {
            --bg: #f8f9fa;
            --card-bg: #ffffff;
            --text: #212529;
            --border: #dee2e6;
            --input-bg: #ffffff;
        }

        body.dark-mode {
            --bg: #000000;         /* True Black Background */
            --card-bg: #1c1c1e;     /* Elevated Grey Card */
            --text: #ffffff;        /* White Text */
            --border: #3a3a3c;      /* Visible Border */
            --input-bg: #000000;    /* High-contrast Black Input "Poles" */
        }

        body { 
            background-color: var(--bg) !important; 
            color: var(--text) !important; 
            transition: background-color 0.2s;
            padding: 20px;
        }

        .add-box { 
            background-color: var(--card-bg); 
            border: 1px solid var(--border);
            border-radius: 15px; 
            padding: 30px; 
            max-width: 600px; 
            margin: auto; 
            box-shadow: 0 10px 25px rgba(0,0,0,0.3);
        }

        label { font-weight: bold; margin-bottom: 8px; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; }
        
        /* THE "POLES" (Input areas) */
        textarea, input.form-control {
            background-color: var(--input-bg) !important;
            color: var(--text) !important;
            border: 2px solid var(--border) !important;
            margin-bottom: 20px;
            border-radius: 10px;
        }

        textarea:focus, input:focus {
            border-color: #0d6efd !important; /* Bright blue "glow" when typing */
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25) !important;
            outline: none;
        }

        .btn-submit { padding: 15px; font-weight: bold; font-size: 1.1rem; border-radius: 12px; }
        
        /* High-Visibility Link */
        .cancel-link { color: #0d6efd !important; font-weight: 600; text-decoration: none; }
        .cancel-link:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="add-box">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="m-0 fw-bold">Create New Card</h4>
            <button onclick="toggleDarkMode()" class="btn btn-sm btn-outline-secondary" id="themeBtn">🌙</button>
        </div>

        <form method="POST" enctype="multipart/form-data">
            <label>Front Side (Question)</label>
            <textarea name="front" rows="3" class="form-control" placeholder="What are you learning?" required></textarea>
            
            <label>Back Side (Answer)</label>
            <textarea name="back" rows="5" class="form-control" placeholder="The definition or translation..." required></textarea>

            <label>Image Attachment</label>
            <input type="file" name="image" accept="image/*" class="form-control">
            
            <div class="d-grid gap-2 mt-4 text-center">
                <button type="submit" class="btn btn-primary btn-submit shadow">Save to Library</button>
                <a href="/" class="cancel-link mt-2">Cancel and Exit</a>
            </div>
        </form>
    </div>

    <script>
        function toggleDarkMode() {
            const isDark = document.body.classList.toggle('dark-mode');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
            updateBtn(isDark);
        }
        function updateBtn(isDark) {
            document.getElementById('themeBtn').innerHTML = isDark ? '☀️' : '🌙';
        }
        (function() {
            if (localStorage.getItem('theme') === 'dark') {
                document.body.classList.add('dark-mode');
                updateBtn(true);
            }
        })();
    </script>
</body>
</html>
